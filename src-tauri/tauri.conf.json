{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nodepad",
  "version": "0.1.0",
  "identifier": "com.nodepad.desktop",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "Nodepad", "width": 900, "height": 700, "resizable": true }],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'" }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": []
  }
}
